     </size>
    </property>
    <property name="styleSheet">
     <string notr="true">QTableWidget {
    background-color: #F8F9FA;   /* Fond gris très clair */
    color: #1B2631;              /* Texte bleu foncé */
    border: 2px solid #1F4E78;   /* Bordure extérieure */
    gridline-color: #5D6D7E;     
    font-size: 12px;  /* Réduction de la taille de police */
    selection-background-color: #D6EAF8;
    selection-color: #1B2631;
}

QTableWidget::item {
    padding: 1px; /* Réduction maximale du padding */
}

QTableWidget::item:selected {
    background-color: #D6EAF8;
    color: #1B2631;
}

/* En-tête de colonne */
QHeaderView::section {
    background-color: #1F4E78;
    color: white;
    padding: 1px;  /* Réduction maximale du padding */
    font-weight: bold;
    border: 1px solid #154360;
    border-left: none;
    border-right: none;
    min-width: 10px;  /* Colonnes encore plus petites */
    max-width: 40px;  /* Réduction encore plus prononcée */
    font-size: 11px;  /* Diminution supplémentaire de la taille du texte */
}

/* Supprimer la bordure gauche de la première colonne */
QHeaderView::section:first {
    border-left: 1px solid #154360;
}

/* Supprimer la bordure droite de la dernière colonne */
QHeaderView::section:last {
    border-right: 1px solid #154360;
}

/* Effet au survol */
QHeaderView::section:hover {
    background-color: #154360;
}

/* Supprimer la numérotation des lignes */
QTableWidget QHeaderView::section:vertical {
    background: transparent;
    border: none;
    min-width: 0px;
    max-width: 0px;
    width: 0px;
}

/* Bouton de coin */
QTableCornerButton::section {
    background-color: #1F4E78;
    border: 1px solid #154360;
}
</string>
