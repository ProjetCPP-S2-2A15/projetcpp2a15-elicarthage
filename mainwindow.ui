     <property name="styleSheet">
      <string notr="true">QPushButton {
    background-color: #2C3E50;  /* Bleu foncé professionnel */
    color: white;               /* Texte blanc pour un bon contraste */
    border-radius: 6px;         /* Coins légèrement arrondis */
    padding: 6px 12px;          /* Espacement réduit pour un design plus compact */
    font-size: 13px;            /* Texte plus petit et plus élégant */
    font-weight: normal;        /* Texte normal pour un style minimaliste */
    border: 1px solid #1A252F;  /* Bordure discrète légèrement plus foncée */
}

/* Lorsque le bouton est survolé */
QPushButton:hover {
    background-color: #34495E;  /* Bleu légèrement plus clair au survol */
    border: 1px solid #2C3E50;  /* Bordure harmonisée */
}

/* Lorsque le bouton est pressé */
QPushButton:pressed {
    background-color: #1A252F;  /* Bleu encore plus foncé lorsqu'on clique */
}

/* Lorsque le bouton est désactivé */
QPushButton:disabled {
    background-color: #95A5A6;  /* Gris bleuté pour un bouton désactivé */
    color: #D0D3D4;             /* Texte plus clair pour indiquer l’inactivité */
    border: 1px solid #7F8C8D;  /* Bordure gris clair pour l'inactivité */
}
</string>
