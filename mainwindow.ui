      <property name="styleSheet">
       <string notr="true">/* Style de base pour QComboBox */
QComboBox {
    background-color: #FFFFFF;
    color: #2C3E50;
    border: 2px solid #1F4E78;
    border-radius: 6px;
    padding: 6px;
    font-size: 11.8px;
    selection-background-color: #5DADE2;
    selection-color: white;
    min-width: 6em; /* Largeur minimale pour éviter un rétrécissement excessif */
}

/* Style de la flèche déroulante */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: right center;
    width: 20px;
    border-left: 2px solid #1F4E78;
    border-radius: 0 4px 4px 0;
}

QComboBox::down-arrow {
   /* Optionnel : remplacer par SVG */
    width: 12px;
    height: 12px;
}

/* Style au survol */
QComboBox:hover {
    background-color: #F2F4F5;
    border-color: #1F4E78;
}

/* Style quand éditable */
QComboBox:editable {
    background: white;
}

/* Style au focus */
QComboBox:focus {
    border: 2px solid #1F4E78;
    background-color: #F2F4F5;
}

/* Style de la liste déroulante */
QComboBox QAbstractItemView {
    border: 2px solid #1F4E78;
    border-radius: 6px;
    background: white;
    selection-background-color: #5DADE2;
    outline: 0;
    margin: 0; /* Enlève l'espace autour de la liste */
}

/* Style des éléments dans la liste */
QComboBox QAbstractItemView::item {
    padding: 6px;
    color: #2C3E50;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #EBF5FB;
}

/* Style désactivé */
QComboBox:disabled {
    background-color: #ECF0F1;
    color: #7F8C8D;
    border-color: #BDC3C7;
}</string>
