      <property name="styleSheet">
       <string notr="true">QLineEdit {
    background-color: #FFFFFF;    /* Fond blanc pour une bonne lisibilité */
    color: #2C3E50;               /* Texte bleu foncé */
    border: 2px solid #1F4E78;    /* Bordure bleu foncé */
    border-radius: 6px;           /* Coins arrondis */
    padding: 6px;                 /* Espacement intérieur */
    font-size: 13px;              /* Taille de la police équilibrée */
    selection-background-color: #5DADE2; /* Bleu clair pour la sélection du texte */
    selection-color: white;       /* Texte blanc quand sélectionné */
}

QLineEdit:focus {
    border: 2px solid #222D52;    /* Bordure bleu plus clair au focus */
    background-color: #ECF0F1;    /* Fond gris clair subtil au focus */
}
</string>
