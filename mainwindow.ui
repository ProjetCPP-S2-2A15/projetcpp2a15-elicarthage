    background-color: #1F4E78;   /* Fond du bouton déroulant */
    border-left: 2px solid #154360;
    width: 20px;
}

QComboBox QAbstractItemView {
    background-color: #34495E;   /* Fond de la liste déroulante */
    color: white;                /* Texte blanc */
    border: 1px solid #1F4E78;
    selection-background-color: #5DADE2;  /* Bleu clair pour l'élément sélectionné */
    selection-color: #1B2631;  /* Texte foncé pour la sélection */
}
</string>
