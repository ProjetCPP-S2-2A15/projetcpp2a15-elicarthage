     <string notr="true">QWidget {
    background-color: rgba(240, 240, 240, 1); /* Gris très clair */
    background-image: url(&quot;back.jpg&quot;); /* Ton image de fond */
    background-repeat: no-repeat; /* Evite la répétition de l'image */
    background-position: center; /* Centre l'image */
    background-size: cover; /* Couvre toute la surface du widget */
}
