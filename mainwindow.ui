    <widget class="QTableView" name="tableView">
     <property name="enabled">
      <bool>true</bool>
     </property>
     <property name="geometry">
      <rect>
       <x>410</x>
       <y>70</y>
       <width>831</width>
       <height>261</height>
      </rect>
     </property>
     <property name="cursor" stdset="0">
      <cursorShape>ArrowCursor</cursorShape>
     </property>
     <property name="styleSheet">
      <string notr="true">QTableView {
    background-color: #F8F9FA;   /* Fond gris très clair */
    color: #1B2631;              /* Texte bleu foncé */
    border: 2px solid #1F4E78;   /* Bordure extérieure */
    gridline-color: #5D6D7E;     
    font-size: 12px;  /* Réduction de la taille de police */
    selection-background-color: #D6EAF8;
    selection-color: #1B2631;
}

QTableView::item {
    padding: 1px; /* Réduction maximale du padding */
}

QTableView::item:selected {
    background-color: #D6EAF8;
    color: #1B2631;
}

/* En-tête de colonne */
QHeaderView::section {
    background-color: #1F4E78;
    color: white;
    padding: 1px;  /* Réduction maximale du padding */
    font-weight: bold;
    border: 1px solid #154360;
    border-left: none;
    border-right: none;
    min-width: 10px;  /* Colonnes encore plus petites */
    max-width: 40px;  /* Réduction encore plus prononcée */
    font-size: 11px;  /* Diminution supplémentaire de la taille du texte */
}

/* Supprimer la bordure gauche de la première colonne */
QHeaderView::section:first {
    border-left: 1px solid #154360;
}

/* Supprimer la bordure droite de la dernière colonne */
QHeaderView::section:last {
    border-right: 1px solid #154360;
}

/* Effet au survol */
QHeaderView::section:hover {
    background-color: #154360;
}

/* Supprimer la numérotation des lignes */
QTableView QHeaderView::section:vertical {
    background: transparent;
    border: none;
    min-width: 0px;
    max-width: 0px;
    width: 0px;
}

/* Bouton de coin */
QTableCornerButton::section {
    background-color: #1F4E78;
    border: 1px solid #154360;
}
</string>
     </property>
    </widget>
    <widget class="QLineEdit" name="lineEdit_IDS">
     <property name="geometry">
      <rect>
       <x>980</x>
       <y>350</y>
       <width>113</width>
       <height>31</height>
      </rect>
     </property>
     <property name="styleSheet">
      <string notr="true">/* Style par défaut du QLineEdit */
QLineEdit {
    background-color: #FFFFFF;    /* Fond blanc pour une bonne lisibilité */
    color: #2C3E50;               /* Texte bleu foncé */
    border: 2px solid #1F4E78;    /* Bordure bleu foncé */
    border-radius: 6px;           /* Coins arrondis */
    padding: 6px;                 /* Espacement intérieur */
    font-size: 13px;              /* Taille de la police équilibrée */
    selection-background-color: #5DADE2; /* Bleu clair pour la sélection du texte */
    selection-color: white;       /* Texte blanc quand sélectionné */
}

/* Style lorsque le QLineEdit est en focus */
QLineEdit:focus {
    border: 2px solid #222D52;    /* Bordure bleu plus clair au focus */
    background-color: #ECF0F1;    /* Fond gris clair subtil au focus */
}

/* Style d'erreur : bordure rouge */
QLineEdit.error {
    border: 2px solid red;  /* Bordure rouge en cas d'erreur */
}
</string>
     </property>
     <property name="placeholderText">
      <string>ID</string>
     </property>
    </widget>
    <widget class="QPushButton" name="btnsupprimer">
     <property name="geometry">
