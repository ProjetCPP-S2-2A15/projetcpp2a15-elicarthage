     <property name="styleSheet">
      <string notr="true">QWidget {
    background-color: #eee5d3; 
    border: 1px solid black;   /* Cadre noir fin (1px) */
    border-radius: 20px; /* Coins arrondis */
}

QWidget &gt; * {
    border: none; /* Désactive la bordure pour les éléments enfants */
}

/* Gestion de la position des éléments */
QGridLayout {
    spacing: 10px;  /* Espacement entre les widgets */
    margin: 20px;   /* Marge autour du layout */
}

QLabel {
    qproperty-alignment: AlignRight | AlignVCenter; /* Alignement des labels */
}

QLineEdit, QComboBox {
    qproperty-alignment: AlignLeft | AlignVCenter; /* Alignement des champs */
    min-width: 200px;
}

QPushButton {
    qproperty-alignment: AlignCenter; /* Centrage des boutons */
    margin-top: 20px;
}</string>
     </property>
