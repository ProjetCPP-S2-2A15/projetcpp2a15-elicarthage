     <property name="styleSheet">
      <string notr="true">/* Style général du QGroupBox */
QWidget {
    border: none; /* Supprime le cadre du groupe */
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:0, y2:1,
        stop:0 rgba(34, 32, 82, 255),
        stop:1 rgba(0, 0, 0, 255)); /* Dégradé */
    border-radius: 10px; /* Coins arrondis */
    padding: 10px; /* Espace intérieur */
}

/* Style des boutons */
QPushButton {
    background-color: transparent; /* Fond transparent par défaut */
    color: white; /* Texte blanc */
    border: none;
    padding: 10px;
    font-size: 16px;
    min-width: 120px; /* Largeur minimale du bouton */
    min-height: 40px; /* Hauteur minimale du bouton */
}

/* Effet au survol */
QPushButton:hover {
    background-color: rgba(255, 255, 255, 0.1); /* Léger fond blanc transparent au survol */
}

/* Effet quand le bouton est pressé */
QPushButton:pressed {
    background-color: white; /* Fond blanc */
    color: black; /* Texte noir */
}

/* Quand le bouton est coché, il reste en blanc */
QPushButton:checked {
    background-color: white; /* Fond blanc après clic */
    color: black; /* Texte noir après clic */
}

/* Style du QLabel */
QLabel {
    color: white; /* Texte en blanc */
    font-family: Arial, sans-serif; /* Police Arial */
    font-size: 16px; /* Taille de la police */
    font-weight: bold; /* Police en gras */
    padding: 5px; /* Espace autour du texte */
}
QPushButton#architecte {
    qproperty-icon: url(C:/Users/user/OneDrive/Documents/archi/engineer.png);
    qproperty-iconSize: 24px 24px;
}

QPushButton#projet {
    qproperty-icon: url(C:/Users/user/OneDrive/Documents/archi/dossier.png);
    qproperty-iconSize: 24px 24px;
}

QPushButton#tache {
    qproperty-icon: url(C:/Users/user/OneDrive/Documents/archi/taches.png);
    qproperty-iconSize: 24px 24px;
}

QPushButton#client {
    qproperty-icon:url(C:/Users/user/OneDrive/Documents/archi/user.png);
    qproperty-iconSize: 24px 24px;
}

QPushButton#formations {
    qproperty-icon:url(C:/Users/user/OneDrive/Documents/archi/learning.png);
  qproperty-iconSize: 24px 24px;
}
QPushButton#ressources {
    qproperty-icon:url(C:/Users/user/OneDrive/Documents/archi/loan.png);
  qproperty-iconSize: 24px 24px;
}

QPushButton#deconnecter {
    qproperty-icon:url(C:/Users/Admin/Desktop/projet/images/deconnexion.png);
  qproperty-iconSize: 24px 24px;
}
QPushButton#logo {
    qproperty-icon: url(C:/Users/Admin/Desktop/projet/images/logo.png);
    qproperty-iconSize: 70px 70px; /* Taille augmentée */
}



</string>
