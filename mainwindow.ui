    qproperty-iconSize: 24px 24px;
}

QPushButton#client {
    qproperty-icon:url(C:/Users/user/OneDrive/Documents/archi/user.png);
    qproperty-iconSize: 24px 24px;
}

QPushButton#formations {
    qproperty-icon:url(C:/Users/user/OneDrive/Documents/archi/learning.png);
  qproperty-iconSize: 24px 24px;
}
QPushButton#ressources {
    qproperty-icon:url(C:/Users/user/OneDrive/Documents/archi/loan.png);
  qproperty-iconSize: 24px 24px;
}

QPushButton#deconnecter {
    qproperty-icon:url(C:/Users/Admin/Desktop/projet/images/deconnexion.png);
  qproperty-iconSize: 24px 24px;
}
QPushButton#logo {
    qproperty-icon: url(C:/Users/Admin/Desktop/projet/images/logo.png);
    qproperty-iconSize: 70px 70px; /* Taille augmentée */
}



</string>
