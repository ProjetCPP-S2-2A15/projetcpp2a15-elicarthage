        <property name="styleSheet">
         <string notr="true">QTableWidget {
    background-color: #F8F9FA;   /* Fond gris très clair pour une meilleure lisibilité */
    color: #1B2631;              /* Texte bleu foncé/gris anthracite */
    border: 2px solid #1F4E78;   /* Bordure bleu foncé */
    border-radius: 8px;
    gridline-color: #5D6D7E;     /* Couleur des lignes de grille */
    font-size: 14px;
    selection-background-color: #D6EAF8; /* Fond bleu clair pour la sélection */
    selection-color: #1B2631;   /* Texte bleu foncé pour l'élément sélectionné */
}

QTableWidget::item {
    padding: 8px;
}

QTableWidget::item:selected {
    background-color: #D6EAF8;  /* Bleu clair pour l'élément sélectionné */
    color: #1B2631;             /* Texte bleu foncé */
}

QHeaderView::section {
    background-color: #1F4E78;  /* En-tête de colonne bleu foncé */
    color: white;               /* Texte blanc dans l'en-tête */
    padding: 6px;
    font-weight: bold;
    border: 1px solid #154360;
}

QHeaderView::section:hover {
    background-color: #154360;  /* Bleu plus foncé au survol */
}

QTableCornerButton::section {
    background-color: #1F4E78; /* Bouton de coin en bleu foncé */
    border: 1px solid #154360;
}
</string>
